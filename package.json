{
  "name": "portfolio-logan",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "browserslist": [
    "chrome >= 108",
    "firefox >= 110",
    "safari >= 16",
    "edge >= 108",
    "not dead"
  ],
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "prettier --write . --ignore-path .gitignore",
    "lint": "next lint",
    "lint:fix": "npm run format && npm run lint -- --fix",
    "start": "next start",
    "type-check": "tsc --noEmit"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.21.0",
    "@tailwindcss/typography": "^0.5.19",
    "next": "^16.2.4",
    "next-sanity": "^12.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.21.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "eslint": "^9.27.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^2.5.21",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.17"
  }
}
